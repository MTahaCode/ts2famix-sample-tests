SmalltalkCISpec {
  #loading : [
    SCIMetacelloLoadSpec {
      #baseline : 'FamixTypeScript',
      #repository : 'github://fuhrmanator/FamixTypeScript:master/src',
      #platforms : [ #pharo ]
    },
    SCIMetacelloLoadSpec {
      #baseline : 'FamixTypeScript',
      #directory : '../tests',
      #load : [ 'Famix-TypeScript-Importer-Tests' ],
      #platforms : [ #pharo ]
    }
  ],
  #testing : {
    #packages : [ 'Famix-TypeScript-Importer-Tests' ]
  }
}